generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int              @id @default(autoincrement())
  email           String           @unique
  passwordHash    String
  role            String           @default("applicant")
  createdAt       DateTime         @default(now())
  profile         UserProfile?
  achievements    Achievement[]
  testResults     TestResult[]
  recommendations Recommendation[]
}

model UserProfile {
  id                  Int      @id @default(autoincrement())
  userId              Int      @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String?
  city                String?
  educationLevel      String?
  institutionTypePref String?
  interests           String[]
  favoriteSubjects    String[]
  birthYear           Int?
}

model Achievement {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  grade       Int?
  subject     String?
  documentUrl String?
  createdAt   DateTime @default(now())
}

model TestResult {
  id              Int              @id @default(autoincrement())
  userId          Int
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalityType String?
  answersJson     Json?
  totalScore      Int?
  takenAt         DateTime         @default(now())
  recommendations Recommendation[]
}

model Profession {
  id              Int              @id @default(autoincrement())
  name            String
  sphere          String
  description     String?
  requiredSkills  String[]
  educationLevel  String?
  specialties     Specialty[]
  recommendations Recommendation[]
}

model Specialty {
  id               Int        @id @default(autoincrement())
  professionId     Int
  profession       Profession @relation(fields: [professionId], references: [id])
  name             String
  code             String?
  eduLevel         String
  requiredSubjects String[]
  programs         Program[]
}

model Institution {
  id            Int       @id @default(autoincrement())
  name          String
  type          String
  city          String
  website       String?
  accreditation String?
  programs      Program[]
}

model Program {
  id             Int              @id @default(autoincrement())
  specialtyId    Int
  specialty      Specialty        @relation(fields: [specialtyId], references: [id])
  institutionId  Int
  institution    Institution      @relation(fields: [institutionId], references: [id])
  studyForm      String?
  minEntScore    Int?
  tuitionCost    Decimal?
  hasGrant       Boolean          @default(false)
  durationYears  Int?
  language       String?
  recommendations Recommendation[]
}

model Recommendation {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  testResultId Int?
  testResult   TestResult? @relation(fields: [testResultId], references: [id])
  professionId Int?
  profession   Profession? @relation(fields: [professionId], references: [id])
  programId    Int?
  program      Program?   @relation(fields: [programId], references: [id])
  matchScore   Decimal?
  matchReason  String?
  createdAt    DateTime   @default(now())
}
